# Copy to .env and fill in. The runtime reads GEMINI_API_KEY explicitly.
GEMINI_API_KEY=...

# Optional stage model choices: flash or pro only.
# JANTRA_MODEL_INTAKE=flash
# JANTRA_MODEL_RESEARCH=flash
# JANTRA_MODEL_PLANNING=pro

# Remote/hosted API (npm run server:remote, behind the Cloudflare edge).
# JANTRA_REMOTE_API_KEYS=somekey:xolver:web   # comma list of key:clientId[:subject]
# Operator-only key console. Generate with:
# node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
# JANTRA_ADMIN_TOKEN=...
# JANTRA_SERVER_HOST=0.0.0.0
# JANTRA_SERVER_PORT=4317

# Local API (npm run server): extra dev origins for browser widget testing.
# JANTRA_ALLOWED_ORIGINS=http://localhost:5176

# Optional runtime controls.
# JANTRA_PROVIDER=gemini        # gemini | mock | openai-compatible

# --- Any LLM via an OpenAI-compatible API (OpenRouter, OpenAI, DeepSeek, etc.) ---
# Set JANTRA_PROVIDER=openai-compatible and configure the four vars below.
# Switch models by changing JANTRA_MODEL alone — no code changes.
# Grounded research still runs on Gemini (hybrid), so keep GEMINI_API_KEY set too.
# JANTRA_BASE_URL=https://openrouter.ai/api/v1   # OpenAI: https://api.openai.com/v1, DeepSeek: https://api.deepseek.com
# JANTRA_API_KEY=sk-or-...                        # key for the base URL above
# JANTRA_MODEL=anthropic/claude-sonnet-4          # flash-tier slot (default model)
# JANTRA_MODEL_PRO=anthropic/claude-opus-4        # pro-tier slot (defaults to JANTRA_MODEL)
# JANTRA_PRICE_INPUT=0      # USD per 1M input tokens, for cost tracking when the API does not report cost
# JANTRA_PRICE_OUTPUT=0     # USD per 1M output tokens (OpenRouter reports real cost, so these can stay 0)
# JANTRA_DATA_COLLECTION=deny  # OpenRouter only: deny | allow. "deny" routes only to providers that do
#                              # not store/train on inputs. Omitted by default; ignored by non-OpenRouter endpoints.
#
# --- DeepSeek V4 Flash via OpenRouter (all stages: intake, research, planning) ---
# Intake and Research use the flash tier (JANTRA_MODEL); Planning uses the pro
# tier (JANTRA_MODEL_PRO). Set both to the same DeepSeek checkpoint to route
# every stage through DeepSeek by default. Users can still override per-run in
# the UI by selecting a different catalog model.
#
# JANTRA_PROVIDER=openai-compatible
# JANTRA_BASE_URL=https://openrouter.ai/api/v1
# JANTRA_API_KEY=sk-or-...                          # your OpenRouter key
# JANTRA_MODEL=deepseek/deepseek-v4-flash           # intake + research (flash tier)
# JANTRA_MODEL_PRO=deepseek/deepseek-v4-flash       # planning — PRD, TRD, build plan (pro tier)
# OpenRouter reports real per-call cost, so JANTRA_PRICE_* can stay 0. To set
# them explicitly: V4 Flash is $0.0983 / $0.1966 per 1M input/output tokens.

# JANTRA_EXPLICIT_CACHE=true
# JANTRA_AUDIT_DIR=.jantra/audit
# JANTRA_AUDIT_MAX_FIELD_BYTES=16384    # tune to your cost profile; 0 disables truncation
# JANTRA_PROJECT_DIR=.jantra/projects
# JANTRA_LEAD_DIR=.jantra/leads            # where captured marketing leads are stored

# Lead attribution: verify end-user Logto tokens forwarded by the edge proxy in
# the X-Jantra-User header (POST /v1/leads attribution, GET /v1/leads listing).
# Defaults target the prod Logto tenant; override for other tenants.
# JANTRA_LOGTO_ISSUER=https://auth.xolver.in/oidc
# JANTRA_LOGTO_AUDIENCE=https://api.jantra.in
# JANTRA_LOGTO_JWKS_URL=https://auth.xolver.in/oidc/jwks
# JANTRA_MAX_STEPS=16
# JANTRA_MAX_USER_MESSAGE_CHARS=100000      # tune to your cost profile
# JANTRA_MAX_OUTPUT_TOKENS=12000
# JANTRA_THINKING_BUDGET=4096       # tune to your cost profile; -1 enables dynamic thinking
# JANTRA_COST_CEILING_USD=10
# JANTRA_INTAKE_RUN_CEILING_USD=0.25              # tune to your cost profile; 0 disables
# JANTRA_INTAKE_CLIENT_DAILY_CEILING_USD=0.50     # tune to your cost profile; 0 disables
# JANTRA_RESEARCH_CONCURRENCY=4      # capped at 8 to avoid rate-limit spikes
# JANTRA_SYNTHESIS_CONCURRENCY=3     # capped at 6
# JANTRA_MAX_SOURCES=24             # capped at 48 fetched sources per research run
